EMBED_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
MCP_PORT=8765
MCP_HOST=0.0.0.0
MCP_WORKSPACE_HEADER=X-Memory-Workspace
MCP_SESSION_HEADER=X-Memory-Session-Id

ASYNC_DATABASE_URL_V3=postgresql://memory:memory@localhost:5432/memory_v3
DATABASE_URL_V3=postgresql+psycopg2://memory:memory@localhost:5432/memory_v3
MEMORY_V3_BRING_TO_MIND_IDLE_RESET_MINUTES=30
MEMORY_V3_BRING_TO_MIND_SEARCH_LIMIT=12
MEMORY_V3_BRING_TO_MIND_RESULT_LIMIT=6
MEMORY_V3_RECALL_SEARCH_LIMIT=5
MEMORY_V3_QUERY_OBSERVATIONS_SEARCH_LIMIT=100
MEMORY_V3_SEARCH_RECENT_OBSERVATION_WINDOW_DAYS=7
MEMORY_V3_SEARCH_RECENT_OBSERVATION_BONUS=0.05
MEMORY_V3_SEARCH_UNDERSTANDING_SCORE_MULTIPLIER=1.15
MEMORY_V3_DENSE_INTERSECTION_MIN_SIZE=2
